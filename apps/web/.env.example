# Client (exposed via Vite)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_APP_ENV=development

# Backend REST API (apps/api) — si está presente, los repositorios usan API
# por defecto en lugar de Dexie. Se puede forzar localStorage en runtime.
VITE_API_URL=http://localhost:3001

# Supabase Edge Functions (server-side only - never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# RESEND_API_KEY=your_resend_api_key