{
  "framework": "vite",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=web",
  "devCommand": "cd ../.. && pnpm turbo dev --filter=web",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}