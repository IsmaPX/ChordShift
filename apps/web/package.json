{
  "name": "web",
  "version": "1.0.3",
  "private": true,
  "author": {
    "name": "IsmaPX",
    "email": "ismaepx@gmail.com"
  },
  "homepage": "https://web-maikel-js-projects.vercel.app",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env VITE_ELECTRON_BUILD=true vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && cross-env VITE_ELECTRON_BUILD=true vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "pack": "electron-builder --dir",
    "dist:win": "npm run build:electron && electron-builder --win --x64",
    "dist:mac": "electron-builder --mac --x64",
    "dist:linux": "electron-builder --linux --x64",
    "dist:all": "electron-builder --win --mac --linux --x64",
    "release": "electron-builder --x64 --publish always"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.62.0",
    "dexie": "^4.4.2",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.15.0",
    "i18next": "^24.0.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.0.0",
    "react-router": "^7.1.0",
    "socket.io-client": "^4.8.1",
    "tone": "^15.0.4",
    "twilio": "^6.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.8.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.0"
  }
}
