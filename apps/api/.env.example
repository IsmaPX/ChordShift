# =============================================================================
# ChordShift / Worship Piano App — API backend
# Copia este archivo a `.env` y rellena los valores reales.
# NO COMMITEES el `.env` (está en .gitignore).
# =============================================================================

# ---------- Entorno ----------
NODE_ENV=development
PORT=3001

# ---------- Base de datos (PostgreSQL) ----------
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# - Local:  postgresql://postgres:postgres@localhost:5432/worship_piano?schema=public
# - Test:   postgresql://postgres:postgres@localhost:5432/worship_piano_test?schema=public
# - Prod:   usa la URL que te dé tu provider (Railway/Render/Fly/Supabase/Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worship_piano?schema=public

# ---------- CORS ----------
# Lista separada por comas de orígenes permitidos para CORS.
# Ejemplo prod: CORS_ORIGIN=https://web-1tmdqw12l-maikel-js-projects.vercel.app,https://chordshift.app
CORS_ORIGIN=http://localhost:5173

# ---------- JWT ----------
# Genera uno con: openssl rand -base64 48
# DEBE tener al menos 32 caracteres.
JWT_SECRET=change-me-please-this-is-a-development-secret-replace-in-prod
JWT_EXPIRES_IN=7d

# ---------- Bcrypt ----------
# Coste del hash. 10-12 es razonable. Más alto = más seguro pero más lento.
BCRYPT_ROUNDS=10

# ---------- Rate limiting (HTTP) ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---------- Live sessions (Socket.IO) ----------
# Tiempo en ms antes de considerar una sesión inactiva (1h por defecto).
SESSION_TTL_MS=3600000

# ---------- Storage ----------
# Driver de almacenamiento de archivos (audio de canciones, etc).
# Valores: 'local' | 's3' | 'supabase'
STORAGE_DRIVER=local

# ---- Local driver ----
# Directorio donde se guardan los archivos cuando STORAGE_DRIVER=local.
# En Docker, suele ser /app/storage o un volumen montado.
# STORAGE_DIR=./storage

# ---- S3 driver ----
# Compatible con AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, etc.
# S3_BUCKET=chordshift-audios
# S3_REGION=us-east-1
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com  # opcional (R2, MinIO)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC=true  # si los assets son públicos (presigned URLs se omiten)
# S3_PUBLIC_URL=https://cdn.tu-dominio.com  # CDN público (opcional)

# ---- Supabase Storage driver ----
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...
# SUPABASE_BUCKET=song-audios

# ---------- Web Push (VAPID) ----------
# Genera con:
#   npx web-push generate-vapid-keys
# Opcionales: si no las defines, las notificaciones push quedan deshabilitadas.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Subject debe ser un mailto: o https:// (RFC 8292 §2).
VAPID_SUBJECT=mailto:admin@worshippiano.app
