# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worship_piano?schema=public"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Auth
JWT_SECRET="cambia-este-secreto-en-produccion-usando-una-variable-de-entorno"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
